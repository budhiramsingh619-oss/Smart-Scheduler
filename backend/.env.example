# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smart_scheduler

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=change_me_generate_a_real_secret

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# 1. Create a project → Enable Gmail API + Google Calendar API
# 2. OAuth consent screen → add scopes: gmail.readonly, calendar, userinfo.email
# 3. Create OAuth 2.0 Client ID (Web application type)
# 4. Add authorised redirect URI: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Frontend URL (for OAuth redirect) ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
